datasource db {
  provider = "postgresql"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

model Service {
  id       String    @id
  name     String
  type     String
  icon     String
  accounts Account[]
}

model Account {
  id            String         @id @default(uuid())
  serviceId     String
  service       Service        @relation(fields: [serviceId], references: [id])
  label         String
  slug          String?        @unique
  email         String         @default("")
  password      String         @default("")
  shareType     String         @default("account") // "account" | "invite"
  totalSlots    Int
  price1m       Float          @default(0)
  price3m       Float          @default(0)
  price6m       Float          @default(0)
  price12m      Float          @default(0)
  renewalDate   String
  notes         String         @default("")
  joinLink      String         @default("")
  requireEmail  Boolean        @default(false)
  imapEmail     String         @default("")
  imapPassword  String         @default("")
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  payments      Payment[]
  orders        Order[]
}

model User {
  id            String         @id @default(uuid())
  name          String
  phone         String
  fbLink        String         @default("")
  lookupPin     String         @default("")
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  payments      Payment[]
}

model Subscription {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  accountId String
  account   Account   @relation(fields: [accountId], references: [id])
  slotLabel String
  startDate String
  endDate   String    @default("")
  duration  Int       @default(1) // months: 1, 3, 6, 12
  status    String    @default("active")
  createdAt DateTime  @default(now())
  payments  Payment[]
}

model Payment {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  amount         Float
  month          String
  status         String       @default("pending")
  paidAt         DateTime?
  note           String       @default("")
  createdAt      DateTime     @default(now())
}

model Settings {
  id               Int    @id @default(1)
  bankId           String @default("MB")
  bankBin          String @default("970422")
  accountNo        String @default("")
  accountName      String @default("")
  reminderDays     Int    @default(7)
  adminPassword    String @default("admin123")
  shopTitle        String @default("Dịch vụ chia sẻ")
  shopDescription  String @default("Đăng ký dịch vụ với giá tốt nhất")
  transferNote     String @default("{sdt}") // template: {sdt} = customer phone
  ogImage          String @default("")
  telegramBotToken  String @default("")
  telegramChatId    String @default("")
  contactFacebook   String @default("")
  contactTelegram   String @default("")
  imapEmail         String @default("")
  imapPassword      String @default("")
}

model Order {
  id                String   @id @default(uuid())
  accountId         String
  account           Account  @relation(fields: [accountId], references: [id])
  customerName      String
  customerPhone     String
  customerFb        String   @default("")
  customerEmail     String   @default("")
  lookupPin         String   @default("")
  amount            Float
  duration          Int      @default(1) // months: 1, 3, 6, 12
  promoCodeId       String?
  status            String   @default("pending") // pending | confirmed | expired
  customerConfirmed Boolean  @default(false)
  paymentProof      String?  // base64 image data URL
  createdAt         DateTime @default(now())
  expiresAt         DateTime
}

model PromoCode {
  id                   String    @id @default(uuid())
  code                 String    @unique
  discountType         String    @default("percent") // "percent" | "fixed"
  discountValue        Float
  applicableAccountIds String[]  @default([])
  expiresAt            DateTime?
  maxUses              Int       @default(0) // 0 = unlimited
  usedCount            Int       @default(0)
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
}
