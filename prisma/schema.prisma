datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Service {
  id       String    @id
  name     String
  type     String
  icon     String
  accounts Account[]
}

model Account {
  id            String         @id @default(uuid())
  serviceId     String
  service       Service        @relation(fields: [serviceId], references: [id])
  label         String
  email         String
  password      String
  totalSlots    Int
  monthlyFee    Float
  renewalDate   String
  notes         String         @default("")
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  payments      Payment[]
  orders        Order[]
}

model User {
  id            String         @id @default(uuid())
  name          String
  phone         String
  fbLink        String         @default("")
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  payments      Payment[]
}

model Subscription {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  accountId String
  account   Account   @relation(fields: [accountId], references: [id])
  slotLabel String
  startDate String
  status    String    @default("active")
  createdAt DateTime  @default(now())
  payments  Payment[]
}

model Payment {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  amount         Float
  month          String
  status         String       @default("pending")
  paidAt         DateTime?
  note           String       @default("")
  createdAt      DateTime     @default(now())
}

model Settings {
  id            Int    @id @default(1)
  bankId        String @default("MB")
  bankBin       String @default("970422")
  accountNo     String @default("")
  accountName   String @default("")
  reminderDays  Int    @default(7)
  adminPassword String @default("admin123")
}

model Order {
  id            String   @id @default(uuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id])
  customerName  String
  customerPhone String
  customerFb    String   @default("")
  amount        Float
  status        String   @default("pending") // pending | confirmed | expired
  createdAt     DateTime @default(now())
  expiresAt     DateTime
}
